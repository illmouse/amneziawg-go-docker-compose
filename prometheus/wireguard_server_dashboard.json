          "refId": "B"
        }
      ],
      "title": "Configured Peers",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "keepLabels": [
              "peer",
              "endpoint"
            ],
            "mode": "columns"
          }
        },
        {
          "id": "joinByField",
          "options": {
            "byField": "peer",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "endpoint 1": true,
              "endpoint 2": true
            },
            "indexByName": {
              "peer": 0,
              "endpoint": 1,
              "wg_peer_rx_bytes_total": 2,
              "wg_peer_tx_bytes_total": 3
            },
            "renameByName": {
              "peer": "Peer Name",
              "endpoint": "Endpoint",
              "wg_peer_rx_bytes_total": "Total RX",
              "wg_peer_tx_bytes_total": "Total TX"
            }
          }
        }
      ],
      "type": "table"
