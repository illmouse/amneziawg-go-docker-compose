      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "max by (instance, interface) (wg_peer_handshake_age_seconds{instance=~\"$instance\"})",
          "instant": true,
          "legendFormat": "{{instance}} {{interface}}",
          "refId": "A"
        }
      ],
      "title": "Handshake Age",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
